# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# ─── 0G COMPUTE (OpenAI-compatible Router) ─────────────────────
# Key from https://pc.testnet.0g.ai → Dashboard → API Keys (inference)
OG_COMPUTE_API_KEY=sk-
# Router base URL — verify against current 0G docs; the Phase 2 smoke test confirms it.
OG_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
# Model: MiniMax-M3 is FREE, native tool use, verifiable, 1M ctx (best default).
# Fallback (cheap, in-house, tool-optimized): 0GM-1.0-35B-A3B
# NOTE: confirm the exact model-id string from the router /models endpoint or
# pc.testnet.0g.ai dashboard — display name may be namespaced (e.g. MiniMaxAI/MiniMax-M3).
OG_COMPUTE_MODEL=qwen2.5-omni

# ─── COGNEE MEMORY (WeMakeDevs × Cognee) ───────────────────────
# Cognee reuses OG_COMPUTE_* above for extraction (minimax-m3 on 0G) and configures BAML +
# local fastembed embeddings in code (app/services/memory.py) — NO OpenAI, no extra keys.
# Only optional override below: where the file-based graph/vector stores live (mount a
# persistent volume here in production; both must persist together).
COGNEE_SYSTEM_ROOT=/app/.cognee_system
COGNEE_DATA_ROOT=/app/.data_storage

# ─── 0G STORAGE (used by Node sidecar) ─────────────────────────
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=          # testnet wallet private key (funded)
STORAGE_SIDECAR_URL=http://storage-sidecar:3001
SIDECAR_AUTH_TOKEN=              # shared secret backend<->sidecar (openssl rand -hex 32)

# ─── 0G CHAIN (OlaRegistry) ────────────────────────────────────
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
# Hardhat/web3 use PRIVATE_KEY; keep it == OG_STORAGE_PRIVATE_KEY for testnet.
PRIVATE_KEY=                     # deployer + backend signer (testnet)
REGISTRY_CONTRACT_ADDRESS=       # filled after deploy

# ─── PAYCREST (Sender API v2) ──────────────────────────────────
# Ola-specific sender account (SEPARATE from Sterling Concierge — one webhook URL per account)
PAYCREST_API_KEY=
PAYCREST_WEBHOOK_SECRET=
PAYCREST_REFUND_ADDRESS=         # EVM address for crypto refunds on failed offramp
PAYCREST_BASE_URL=https://api.paycrest.io/v2
# Default fiat refund account for BUYS (where naira returns if a buy fails). A real,
# valid bank — lets anyone buy with only a wallet. Institution = Paycrest code.
PAYCREST_ONRAMP_REFUND_INSTITUTION=    # e.g. KUDANGPC
PAYCREST_ONRAMP_REFUND_ACCOUNT=        # 10-digit account number
PAYCREST_ONRAMP_REFUND_NAME=           # account holder name

# ─── DATABASE ──────────────────────────────────────────────────
POSTGRES_DB=ola
POSTGRES_USER=ola
POSTGRES_PASSWORD=changeme-REPLACE
DATABASE_URL=postgresql+asyncpg://ola:changeme@db:5432/ola

# ─── APP ───────────────────────────────────────────────────────
SECRET_KEY=                      # openssl rand -hex 32
DEBUG=true

# ─── FRONTEND ──────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_APP_NAME=Ola
